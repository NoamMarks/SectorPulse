{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sectorpulse/contract/latest.schema.json",
  "title": "SectorPulse latest.json",
  "description": "Pre-computed dashboard contract (PRD §10). The frontend renders only these fields and computes nothing.",
  "type": "object",
  "required": [
    "schema_version", "generated_at_utc", "as_of_trading_date",
    "benchmark", "status", "regime", "coverage", "sectors"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "as_of_trading_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "benchmark": { "type": "string" },
    "status": { "enum": ["ok", "stale", "no_trading_day", "partial", "error", "intraday"] },
    "config_hash": { "type": "string" },
    "provider": { "type": "string" },
    "intraday": { "type": "boolean" },
    "as_of_time_utc": { "type": ["string", "null"] },
    "regime": {
      "type": "object",
      "required": ["state", "spy_above_200sma", "pct_sectors_above_200sma"],
      "properties": {
        "state": { "enum": ["risk_on", "neutral", "risk_off"] },
        "spy_above_200sma": { "type": "boolean" },
        "pct_sectors_above_200sma": { "type": "number" }
      }
    },
    "coverage": {
      "type": "object",
      "required": ["symbols_expected", "symbols_ok", "symbols_skipped"],
      "properties": {
        "symbols_expected": { "type": "integer" },
        "symbols_ok": { "type": "integer" },
        "symbols_skipped": { "type": "integer" }
      }
    },
    "sectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ticker", "name", "rss", "rss_rank", "trend", "map_50", "leaders", "setups"],
        "additionalProperties": true,
        "properties": {
          "ticker": { "type": "string" },
          "name": { "type": "string" },
          "rss": { "type": ["number", "null"] },
          "rss_rank": { "type": ["integer", "null"] },
          "rss_slope": { "type": ["number", "null"] },
          "rss_persist": { "type": ["integer", "null"] },
          "trend": { "enum": ["positive", "neutral", "negative"] },
          "breakout": { "type": "boolean" },
          "map_50": { "type": ["number", "null"] },
          "map_200": { "type": ["number", "null"] },
          "map_band": { "enum": ["high", "mid", "low"] },
          "rally_flag": { "type": "boolean" },
          "breadth_divergence": { "type": "boolean" },
          "udvr": { "type": ["number", "null"] },
          "map_granularity_pct": { "type": ["number", "null"] },
          "rss_sparkline": { "type": "array", "items": { "type": ["number", "null"] } },
          "other_count": { "type": "integer" },
          "leaders": { "type": "array", "items": { "$ref": "#/$defs/holding" } },
          "setups": { "type": "array", "items": { "$ref": "#/$defs/holding" } }
        }
      }
    }
  },
  "$defs": {
    "holding": {
      "type": "object",
      "required": ["ticker", "classification"],
      "additionalProperties": true,
      "properties": {
        "ticker": { "type": "string" },
        "name": { "type": "string" },
        "classification": { "enum": ["LEADER", "SETUP", "OTHER"] },
        "rss": { "type": ["number", "null"] },
        "pct_from_52w_high": { "type": ["number", "null"] },
        "pct_from_sma50": { "type": ["number", "null"] },
        "atr_ratio": { "type": ["number", "null"] },
        "vol_contraction": { "type": ["boolean", "null"] },
        "above_sma50": { "type": ["boolean", "null"] },
        "above_sma200": { "type": ["boolean", "null"] },
        "atr_14": { "type": ["number", "null"] },
        "suggested_stop": { "type": ["number", "null"] },
        "suggested_shares": { "type": ["integer", "null"] }
      }
    }
  }
}
